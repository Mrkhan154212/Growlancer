# Copy this file to `.env` and fill in values from the Supabase dashboard:
# Project Settings → API → Project URL & anon public key
#
# Never put real secrets in `.env.example` (this file is committed to git).
# Never commit `.env` (it is gitignored).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Optional: shown in Sentry release tag / health checks
VITE_APP_VERSION=0.0.1

# Optional: Sentry browser DSN (leave empty to disable in production bundle)
VITE_SENTRY_DSN=

# ════════════════════════════════════════════
# PAYMENT PROVIDERS
# ════════════════════════════════════════════

# ── PayPal (for international payments) ──
# Get credentials: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true

# PayPal Webhook (set up in PayPal Developer Dashboard → Webhooks)
# URL: https://YOUR_PROJECT_REF.supabase.co/functions/v1/paypal-webhook
PAYPAL_WEBHOOK_ID=

# ── Razorpay (for Indian payments) ──
# Get credentials: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=

# ════════════════════════════════════════════
# APP URL (used for PayPal return URLs)
# ════════════════════════════════════════════
# ── AI Assistant ──
# Google Gemini API key for the AI Assistant feature
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

APP_URL=https://growlancer.vercel.app

# ════════════════════════════════════════════
# EMAIL (Brevo / Sendinblue)
# ════════════════════════════════════════════
# Get your API key at https://app.brevo.com/settings/keys/api
# IMPORTANT: Set this as a Supabase secret for edge functions:
#   npx supabase secrets set BREVO_API_KEY=<your_key> --project-ref <ref>
#
# Supabase Auth emails (signup confirmation, password reset) are configured
# via SMTP in the Supabase Dashboard → Authentication → Settings → SMTP
# using your Brevo SMTP credentials.
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@growlancer.vercel.app
